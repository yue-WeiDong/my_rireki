    .Alignment = wdAlignParagraphCenter
    End With
Next iRow

    For iRow = 1 To 4
    Set myRange = ActiveDocument.Paragraphs(iRow).Range.Characters(1)
    With myRange.Font
     .Bold = True
     .Name = "微软雅黑"
     .Size = 48
    End With
    Set myRange = ActiveDocument.Paragraphs(iRow).Range.Characters(2)
    With myRange.Font
     .Size = 48
     .Superscript = wdToggle
    End With
    Next iRow

End Sub
Sub FormatText新票()
    ' 定义查找的文本
    Dim findText As String
    findText = "新"
    
    ' 查找文档中的文本
    With Selection.Find
        .Text = findText
        .Replacement.Text = ""
        .Forward = True
        .Wrap = wdFindContinue
        .Format = True
        .MatchCase = False
        .MatchWholeWord = False
        .MatchWildcards = False
        .MatchSoundsLike = False
        .MatchAllWordForms = False
    
        ' 查找下一个匹配项
        While .Execute = True
            ' 找到的文本应用格式
    Selection.Range.ModifyEnclosure Style:=wdEncloseStyleLarge, Symbol:= _
    wdEnclosureCircle
            
            ' 查找下一个匹配项
        Wend
    End With
End Sub
