Sub sanPin() '三品格式设置
With ActiveDocument.PageSetup
.LeftMargin = CentimetersToPoints(0.5)
.RightMargin = CentimetersToPoints(0.5)
End With
  
For iRow = 1 To 4
    Set myRange = ActiveDocument.Paragraphs(iRow).Range
    With myRange.Font
     .Bold = False
     .Name = "仿宋"
     .Size = 24
     End With
     
    With ActiveDocument.Paragraphs(iRow).Range.ParagraphFormat
    .LineSpacingRule = wdLineSpaceExactly
    .LineSpacing = 60
    .Alignment = wdAlignParagraphCenter
    If iRow < 4 Then
        .BaseLineAlignment = wdBaselineAlignFarEast50
    End If
    End With
    
    If iRow < 4 Then
        With myRange.Characters(1).Font
         .Bold = True
         .Name = "微软雅黑"
         .Size = 48
         .Position = -3
        End With
        
        With myRange.Characters(2).Font
         .Size = 48
         .Superscript = wdToggle
        End With
    End If
Next iRow
End Sub
Sub siPin() '四品格式设置
With ActiveDocument.PageSetup
