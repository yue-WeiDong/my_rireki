Sub danPin() '单品格式设置

For iRow = 1 To 2
    Set myRange = ActiveDocument.Paragraphs(iRow).Range
    With myRange.Font
     .Bold = True
     .Name = "微软雅黑"
     .Size = 72
     End With
     
    With ActiveDocument.Paragraphs(iRow).Range.ParagraphFormat
    .LineSpacingRule = wdLineSpaceExactly
    .LineSpacing = 80
    .Alignment = wdAlignParagraphCenter
    End With
Next iRow

ActiveDocument.Paragraphs(1).Range.ParagraphFormat.LineUnitBefore = 2
