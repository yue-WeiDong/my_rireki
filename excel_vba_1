这是一个用于Excel订单数据处理的VBA宏，主要功能如下：

自动备份：创建指定目录结构，保存原始数据和转换后数据的副本
数据格式转换：将原始订单数据转换为标准ERP格式
商品代码映射：根据特定规则将商品代码映射到对应的商品信息和价格
地址拼接：自动组合省市区信息形成完整收货地址
特殊订单检测：识别新疆、西藏、青海等偏远地区订单
液体商品标记：自动标记含液体商品的订单
数据验证：检查价格列是否有空值，确保数据完整性
--------------------------------------------------------------------------------------
Sub ss()
Dim fso, fo, dir As String, dir1 As String, dir2 As String, t1 As Date, t2 As Date, i As Integer

    i = Application.CountA(Range("a:a"))
    Application.DisplayAlerts = False
    dir = "E:/格格家数据备份"
    dir1 = "E:/格格家数据备份/格格家DATA/" '原工作表---备份路径
    dir2 = "E:/格格家数据备份/格格家转ERP/" '转换后工作表---备份路径
    
    On Error Resume Next '忽略错误
    VBA.MkDir (dir): VBA.MkDir (dir1): VBA.MkDir (dir2) '如果没有创建文件夹
    
    filespec = ActiveWorkbook.FullName '获取路径全称
     Set fso = CreateObject("Scripting.FileSystemObject")
     Set fo = fso.GetFile(filespec)
     file_Time = Format(fo.DateCreated, "mm-dd-yy hh_mm_ss") '获取文件创建时间
    If ActiveSheet.Name <> "Sheet0" Then
               
                If MsgBox("活动表名称不是sheet0,是否继续运行吗！", 1) = 2 Then '如何选择2,则退出程序
                    GoTo LastLine
                End If
    End If
            
    If InStr(1, filespec, "_1471") > 0 Then
            shopName = "G"  '格格家
    ElseIf InStr(1, filespec, "_1472") > 0 Then
            shopName = "H"  '环球捕手
    Else
            shopName = "Q"  '其它
                If MsgBox("文件名中不含有_1471或_1472,是否继续运行吗！", 1) = 2 Then '如何选择2,则退出程序
                    GoTo LastLine
                End If
    End If
     file_name_1 = dir1 & "格格家DATA_" & file_Time & "_" & shopName & ".xlsx"    '文件名1
     file_name_2 = dir2 & "格格家转ERP_" & file_Time & "_" & shopName & ".xlsx"   '文件名2
     
     ActiveWorkbook.SaveCopyAs file_name_1 '转换前另存
     
