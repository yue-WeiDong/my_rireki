Sub 提示()
  
  Dim MRG As Range, k As Integer
  k = 0
Set MRG = Range("O:O").Find("新疆")
    If Not MRG Is Nothing Then
    k = k + 1
End If
      
Set MRG = Range("O:O").Find("西藏")
    If Not MRG Is Nothing Then
    k = k + 1
End If

Set MRG = Range("O:O").Find("青海")
    If Not MRG Is Nothing Then
    k = k + 1
End If
    If k > 0 Then
    
    Call 偏远地区替换颜色
